{
    "name": "ais-realtime-tracker",
    "private": true,
    "version": "0.0.0",
    "licence": "MIT",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:client": "vite",
        "dev:server": "tsx server/index.ts",
        "lint": "eslint .",
        "format": "prettier . --write",
        "typecheck": "tsc --noEmit",
        "build": "tsc && vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "mobx": "^6.16.1",
        "mobx-react-lite": "^4.1.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.12.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^10.0.3",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "tsx": "^4.22.4",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.12"
    },
    "engines": {
        "node": ">=24"
    }
}
